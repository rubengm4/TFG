# Copy to algovision/.env and fill in secrets. Never commit .env.
# For production compose substitution, run:
#   docker compose --env-file algovision/.env -f docker-compose.prod.yml up -d

# --- Django core ---
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
# Comma-separated hostnames (no spaces). Must include your public domain.
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.example
# Comma-separated origins with scheme (required behind HTTPS for Django 4+).
CSRF_TRUSTED_ORIGINS=https://your-domain.example
# Set True when TLS is terminated at Caddy/nginx and X-Forwarded-Proto is https.
SECURE_PROXY_SSL=False
# HSTS max-age in seconds (only applied when SECURE_PROXY_SSL=True). Start low, then increase.
SECURE_HSTS_SECONDS=3600

# --- Logging ---
LOG_LEVEL=INFO

# --- Database (Django) ---
# In Docker, HOST is the db service name.
DATABASE_NAME=algovision
DATABASE_USER=algovision
DATABASE_PASSWORD=use-a-strong-password
DATABASE_HOST=db
DATABASE_PORT=3306

# --- MySQL container (docker-compose.prod.yml db service) ---
# Must match DATABASE_* above for the app user.
MYSQL_DATABASE=algovision
MYSQL_USER=algovision
MYSQL_PASSWORD=use-a-strong-password
MYSQL_ROOT_PASSWORD=use-a-different-strong-root-password

# --- Celery / Redis ---
REDIS_URL=redis://redis:6379/0
# REDIS_SSL=true

# --- Media / static paths inside containers ---
DJANGO_MEDIA_ROOT=/app/media

# --- Reverse proxy (production only) ---
# Multiple hosts: comma + space (required by Caddy), e.g. example.com, www.example.com
CADDY_DOMAIN=your-domain.example

# --- Optional: first superuser (bootstrap_initial_data) ---
# DJANGO_SUPERUSER_USERNAME=admin
# DJANGO_SUPERUSER_EMAIL=admin@example.com
# DJANGO_SUPERUSER_PASSWORD=change-me

# --- Gunicorn (production compose overrides) ---
# GUNICORN_WORKERS=3
# GUNICORN_TIMEOUT=300

# --- Algorithm execution ---
# Seconds; 0 = unlimited (not recommended in production).
ALGORITHM_SUBPROCESS_TIMEOUT=3600

# --- Docker entrypoint: skip heavy algenv pip install (CI / debugging only) ---
# SKIP_ALGENV_PIP=1
